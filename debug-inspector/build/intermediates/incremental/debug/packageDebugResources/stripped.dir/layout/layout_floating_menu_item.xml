<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="@dimen/debug_inspector_menu_item_height"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp">

    <ImageView
        android:id="@+id/di_menu_item_icon"
        android:layout_width="@dimen/debug_inspector_menu_icon_size"
        android:layout_height="@dimen/debug_inspector_menu_icon_size"
        android:importantForAccessibility="no"
        tools:src="@drawable/ic_inspect" />

    <TextView
        android:id="@+id/di_menu_item_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:textColor="@color/debug_inspector_text_primary"
        android:textSize="14sp"
        tools:text="View Inspector" />

    <View
        android:id="@+id/di_menu_item_active_dot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_color_chip"
        android:visibility="gone" />

</LinearLayout>
