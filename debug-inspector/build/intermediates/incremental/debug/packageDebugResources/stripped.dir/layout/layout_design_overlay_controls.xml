<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_control_bar"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingHorizontal="10dp"
    android:paddingVertical="8dp">

    <!-- Mode selector row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/di_overlay_mode_opacity"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_control_btn"
            android:gravity="center"
            android:text="@string/debug_inspector_overlay_mode_opacity"
            android:textColor="@color/debug_inspector_text_white"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/di_overlay_mode_slider"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_control_btn"
            android:gravity="center"
            android:text="@string/debug_inspector_overlay_mode_slider"
            android:textColor="@color/debug_inspector_text_white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/di_overlay_mode_flicker"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_control_btn"
            android:gravity="center"
            android:text="@string/debug_inspector_overlay_mode_flicker"
            android:textColor="@color/debug_inspector_text_white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/di_overlay_mode_diff"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:background="@drawable/bg_control_btn"
            android:gravity="center"
            android:text="@string/debug_inspector_overlay_mode_diff"
            android:textColor="@color/debug_inspector_text_white"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Controls row (opacity slider + grid + close) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/di_overlay_opacity_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="@color/debug_inspector_text_white"
            android:textSize="11sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/di_overlay_opacity_slider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="50"
            android:progressTint="@color/debug_inspector_slider_thumb"
            android:thumbTint="@color/debug_inspector_slider_thumb" />

        <ImageView
            android:id="@+id/di_overlay_grid_btn"
            android:layout_width="@dimen/debug_inspector_control_btn_size"
            android:layout_height="@dimen/debug_inspector_control_btn_size"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_control_btn"
            android:contentDescription="@string/debug_inspector_cd_grid"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_grid" />

        <ImageView
            android:id="@+id/di_overlay_close_btn"
            android:layout_width="@dimen/debug_inspector_control_btn_size"
            android:layout_height="@dimen/debug_inspector_control_btn_size"
            android:background="@drawable/bg_control_btn"
            android:contentDescription="@string/debug_inspector_cd_close"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_close" />
    </LinearLayout>
</LinearLayout>
