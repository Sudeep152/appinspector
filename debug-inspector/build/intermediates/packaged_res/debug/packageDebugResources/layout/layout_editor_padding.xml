<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:minHeight="@dimen/debug_inspector_editor_min_height"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="@color/debug_inspector_divider" />

    <!-- Title -->
    <TextView
        android:id="@+id/di_editor_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp"
        android:textColor="@color/debug_inspector_text_primary"
        android:textSize="17sp"
        android:textStyle="bold"
        tools:text="Edit Padding" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/debug_inspector_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/di_padding_preview_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_editor_input"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="@string/debug_inspector_live_preview"
                android:textColor="@color/debug_inspector_live_preview_text"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/debug_inspector_start"
                android:textColor="@color/debug_inspector_text_label"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/di_padding_start"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_editor_input"
                    android:inputType="numberSigned"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/debug_inspector_text_primary"
                    android:textSize="15sp"
                    tools:text="16" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/debug_inspector_dp_unit"
                    android:textColor="@color/debug_inspector_text_label"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/debug_inspector_top"
                android:textColor="@color/debug_inspector_text_label"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/di_padding_top"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_editor_input"
                    android:inputType="numberSigned"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/debug_inspector_text_primary"
                    android:textSize="15sp"
                    tools:text="8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/debug_inspector_dp_unit"
                    android:textColor="@color/debug_inspector_text_label"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/debug_inspector_end"
                android:textColor="@color/debug_inspector_text_label"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/di_padding_end"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_editor_input"
                    android:inputType="numberSigned"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/debug_inspector_text_primary"
                    android:textSize="15sp"
                    tools:text="16" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/debug_inspector_dp_unit"
                    android:textColor="@color/debug_inspector_text_label"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/debug_inspector_bottom"
                android:textColor="@color/debug_inspector_text_label"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/di_padding_bottom"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_editor_input"
                    android:inputType="numberSigned"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/debug_inspector_text_primary"
                    android:textSize="15sp"
                    tools:text="8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/debug_inspector_dp_unit"
                    android:textColor="@color/debug_inspector_text_label"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/debug_inspector_divider" />

    <LinearLayout
        android:id="@+id/di_editor_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <TextView
            android:id="@+id/di_editor_btn_cancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_action_btn"
            android:gravity="center"
            android:text="@string/debug_inspector_cancel"
            android:textColor="@color/debug_inspector_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/di_editor_btn_apply"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_apply_btn"
            android:gravity="center"
            android:text="@string/debug_inspector_apply"
            android:textColor="@color/debug_inspector_apply_btn_text"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
