<?xml version="1.0" encoding="utf-8"?>
<!-- Left border via layer-list: border layer behind, bg layer offset 4dp from left -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/debug_inspector_context_banner_border" />
        </shape>
    </item>
    <item android:left="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/debug_inspector_context_banner_bg" />
        </shape>
    </item>
</layer-list>
