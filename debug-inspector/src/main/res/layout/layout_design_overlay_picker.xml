<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="@dimen/debug_inspector_sheet_padding">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="14dp"
        android:background="@color/debug_inspector_divider" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="@string/debug_inspector_overlay_title"
        android:textColor="@color/debug_inspector_text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Pick from gallery button -->
    <LinearLayout
        android:id="@+id/di_overlay_pick_gallery"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_action_btn"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="@dimen/debug_inspector_menu_icon_size"
            android:layout_height="@dimen/debug_inspector_menu_icon_size"
            android:contentDescription="@string/debug_inspector_cd_gallery"
            android:src="@drawable/ic_gallery" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/debug_inspector_overlay_pick_gallery"
            android:textColor="@color/debug_inspector_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Or label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/debug_inspector_overlay_paste_url"
        android:textColor="@color/debug_inspector_text_label"
        android:textSize="12sp"
        android:textAllCaps="true"
        android:letterSpacing="0.05" />

    <!-- URL input + Load button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/di_overlay_url_input"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_editor_input"
            android:hint="https://..."
            android:importantForAutofill="no"
            android:inputType="textUri"
            android:maxLines="1"
            android:paddingHorizontal="12dp"
            android:textColor="@color/debug_inspector_text_primary"
            android:textColorHint="@color/debug_inspector_text_label"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/di_overlay_btn_load"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/bg_apply_btn"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:text="@string/debug_inspector_overlay_load"
            android:textColor="@color/debug_inspector_apply_btn_text"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Loading indicator -->
    <TextView
        android:id="@+id/di_overlay_loading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:text="@string/debug_inspector_overlay_loading"
        android:textColor="@color/debug_inspector_text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>
