<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@color/debug_inspector_divider" />

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/debug_inspector_hierarchy_title"
            android:textColor="@color/debug_inspector_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Zoom controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/di_zoom_fit"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/debug_inspector_zoom_btn_size"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_zoom_btn"
                android:contentDescription="@string/debug_inspector_cd_zoom_fit"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:text="@string/debug_inspector_zoom_fit"
                android:textColor="@color/debug_inspector_zoom_btn_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/di_zoom_out"
                android:layout_width="@dimen/debug_inspector_zoom_btn_size"
                android:layout_height="@dimen/debug_inspector_zoom_btn_size"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_zoom_btn"
                android:contentDescription="@string/debug_inspector_cd_zoom_out"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_zoom_out" />

            <ImageView
                android:id="@+id/di_zoom_in"
                android:layout_width="@dimen/debug_inspector_zoom_btn_size"
                android:layout_height="@dimen/debug_inspector_zoom_btn_size"
                android:background="@drawable/bg_zoom_btn"
                android:contentDescription="@string/debug_inspector_cd_zoom_in"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_zoom_in" />

        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/debug_inspector_divider" />

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp">

        <EditText
            android:id="@+id/di_hierarchy_search"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_editor_input"
            android:drawablePadding="8dp"
            android:hint="@string/debug_inspector_search_hint"
            android:importantForAutofill="no"
            android:inputType="text"
            android:maxLines="1"
            android:paddingHorizontal="10dp"
            android:textColor="@color/debug_inspector_text_primary"
            android:textColorHint="@color/debug_inspector_text_label"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/di_hierarchy_search_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/debug_inspector_text_secondary"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/debug_inspector_divider" />

    <!-- Zoomable hierarchy area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.shashank.appinspector.utils.ZoomableFrameLayout
            android:id="@+id/di_zoom_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/di_hierarchy_rv"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="16dp"
                android:clipToPadding="false" />

        </com.shashank.appinspector.utils.ZoomableFrameLayout>

        <!-- Scale indicator -->
        <TextView
            android:id="@+id/di_zoom_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="12dp"
            android:background="@color/debug_inspector_highlight_pill_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:text="1.0x"
            android:textColor="@color/debug_inspector_zoom_label_text"
            android:textSize="10sp"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
